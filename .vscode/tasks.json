{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "1. Iniciar pacientes (9081)",
            "type": "shell",
            "command": ".\\mvnw.cmd spring-boot:run",
            "options": {
                "cwd": "${workspaceFolder}/pacientes"
            },
            "isBackground": true,
            "problemMatcher": {
                "owner": "spring-boot",
                "pattern": {
                    "regexp": "^.*$"
                },
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": "^.*Starting.*",
                    "endsPattern": "^.*Started PacientesApplication.*"
                }
            },
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "group": "cdent-backend"
            }
        },
